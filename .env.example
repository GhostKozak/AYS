# ============================================================
# AYS Backend — Environment Variables
# Copy this file to .env and fill in the values.
# NEVER commit your actual .env file to version control!
# ============================================================

# --- Application ---
PORT=3000
NODE_ENV=development
FALLBACK_LANGUAGE=en

# --- MongoDB Connection ---
# Local development (Docker Compose):
MONGODB_URI=mongodb://localhost:27017/ays
# Production example: mongodb+srv://user:pass@cluster.mongodb.net/ays

# --- Cache ---
# TTL in milliseconds (default: 600000 = 10 minutes)
CACHE_TTL=600000

# --- CORS ---
# Frontend origin allowed to connect to the backend API and WebSocket
FRONTEND_URL=http://localhost:5173

# ============================================================
# SECURITY — Change ALL of these before deploying to production
# ============================================================

# JWT signing secret — must be at least 32 random characters
JWT_SECRET=CHANGE_ME_use_a_long_random_secret_at_least_32_chars

# Seed endpoint secrets — used to authenticate POST /seed/admin and /seed/all
SEED_ADMIN_SECRET=CHANGE_ME_seed_admin_secret
SEED_ALL_SECRET=CHANGE_ME_seed_all_secret

# Initial admin account password (used by POST /seed/admin)
INITIAL_ADMIN_PASSWORD=CHANGE_ME_AdminPassword1!

# ============================================================
# System / Audit User
# This account is created automatically during seeding and is
# used internally for audit log attribution. It cannot be
# used to log in normally (login returns 401 for system user).
# ============================================================
SYSTEM_USER_EMAIL=system@internal
SYSTEM_USER_PASSWORD=CHANGE_ME_SystemPassword1!